# Application
APP_NAME=VehicleIQ
DEBUG=true

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Database
DATABASE_URL=postgresql+asyncpg://vehicleiq:vehicleiq@localhost:5432/vehicleiq

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=change-this-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_DAYS=30

# API Keys (Cloud deployment)
GROQ_API_KEY=your-groq-api-key
TOGETHER_API_KEY=your-together-api-key

# AI Services
PADDLEOCR_URL=http://paddleocr:8001
YOLO_URL=http://yolo:8002
EMBEDDINGS_URL=http://embeddings:8003

# Storage
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./storage
SUPABASE_URL=
SUPABASE_KEY=
